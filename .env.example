# Effexiq Environment Variables
# Copy this file to .env.local and fill in real values
# Add these same vars in Vercel Dashboard → Settings → Environment Variables

# ── Supabase ───────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── OpenAI (server-side only — never prefix with NEXT_PUBLIC_) ──
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Cloudflare R2 (server-side only) ──────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=Effexiq-sounds
R2_PUBLIC_URL=https://your-r2-public-bucket-url.r2.dev
NEXT_PUBLIC_R2_PUBLIC_URL=https://your-r2-public-bucket-url.r2.dev

# ── ElevenLabs TTS (server-side only) ────────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9

# ── API Auth (server-side only) ──────────────────────
# Random 32+ char string used to sign API tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_AUTH_SECRET=
